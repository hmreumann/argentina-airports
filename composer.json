{
    "name": "hmreumann/argentina-airports",
    "description": "This is a Package for Laravel to import the airports from Argentina.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Hmreumann\\ArgentinaAirports\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Hmreumann\\ArgentinaAirports\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Hernan Martinez Reumann",
            "email": "hmreumann@hotmail.com"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/console": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Hmreumann\\ArgentinaAirports\\Providers\\ArgentinaAirportsServiceProvider"
            ]
        }
    }
}
